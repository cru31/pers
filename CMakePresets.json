{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default Build",
      "description": "Default build configuration",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "debug",
      "inherits": "default",
      "displayName": "Debug Build",
      "description": "Debug build configuration",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "inherits": "default",
      "displayName": "Release Build",
      "description": "Release build configuration",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "windows-debug",
      "inherits": "debug",
      "displayName": "Windows Debug",
      "description": "Windows-specific debug build",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "generator": "Ninja",
      "cacheVariables": {
        "BUILD_TESTS": "ON",
        "VCPKG_MANIFEST_FEATURES": "tests"
      }
    },
    {
      "name": "windows-release",
      "inherits": "release",
      "displayName": "Windows Release",
      "description": "Windows-specific release build",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "generator": "Ninja",
      "cacheVariables": {
        "BUILD_TESTS": "ON",
        "VCPKG_MANIFEST_FEATURES": "tests"
      }
    },
    {
      "name": "linux-debug",
      "inherits": "debug",
      "displayName": "Linux Debug",
      "description": "Linux-specific debug build",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "generator": "Ninja",
      "cacheVariables": {
        "BUILD_TESTS": "ON",
        "VCPKG_MANIFEST_FEATURES": "tests"
      }
    },
    {
      "name": "linux-release",
      "inherits": "release",
      "displayName": "Linux Release",
      "description": "Linux-specific release build",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "generator": "Ninja",
      "cacheVariables": {
        "BUILD_TESTS": "ON",
        "VCPKG_MANIFEST_FEATURES": "tests"
      }
    },
    {
      "name": "macos-debug",
      "inherits": "debug",
      "displayName": "macOS Debug",
      "description": "macOS-specific debug build",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "generator": "Xcode",
      "cacheVariables": {
        "BUILD_TESTS": "ON",
        "VCPKG_MANIFEST_FEATURES": "tests"
      }
    },
    {
      "name": "macos-release",
      "inherits": "release",
      "displayName": "macOS Release",
      "description": "macOS-specific release build",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "generator": "Xcode",
      "cacheVariables": {
        "BUILD_TESTS": "ON",
        "VCPKG_MANIFEST_FEATURES": "tests"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "displayName": "Build Debug",
      "description": "Build with debug configuration"
    },
    {
      "name": "release",
      "configurePreset": "release",
      "displayName": "Build Release",
      "description": "Build with release configuration"
    },
    {
      "name": "windows-debug",
      "configurePreset": "windows-debug",
      "displayName": "Build Windows Debug",
      "description": "Build Windows debug configuration"
    },
    {
      "name": "windows-release",
      "configurePreset": "windows-release",
      "displayName": "Build Windows Release",
      "description": "Build Windows release configuration"
    },
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug",
      "displayName": "Build Linux Debug",
      "description": "Build Linux debug configuration"
    },
    {
      "name": "linux-release",
      "configurePreset": "linux-release",
      "displayName": "Build Linux Release",
      "description": "Build Linux release configuration"
    },
    {
      "name": "macos-debug",
      "configurePreset": "macos-debug",
      "displayName": "Build macOS Debug",
      "description": "Build macOS debug configuration"
    },
    {
      "name": "macos-release",
      "configurePreset": "macos-release",
      "displayName": "Build macOS Release",
      "description": "Build macOS release configuration"
    }
  ],
  "testPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "displayName": "Test Default",
      "description": "Run tests with default configuration",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-debug",
      "configurePreset": "windows-debug",
      "inherits": "default",
      "displayName": "Test Windows Debug"
    },
    {
      "name": "windows-release",
      "configurePreset": "windows-release",
      "inherits": "default",
      "displayName": "Test Windows Release"
    },
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug",
      "inherits": "default",
      "displayName": "Test Linux Debug"
    },
    {
      "name": "linux-release",
      "configurePreset": "linux-release",
      "inherits": "default",
      "displayName": "Test Linux Release"
    },
    {
      "name": "macos-debug",
      "configurePreset": "macos-debug",
      "inherits": "default",
      "displayName": "Test macOS Debug"
    },
    {
      "name": "macos-release",
      "configurePreset": "macos-release",
      "inherits": "default",
      "displayName": "Test macOS Release"
    }
  ]
}